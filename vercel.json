{
  "version": 2,
  "buildCommand": "pnpm install --no-frozen-lockfile && pnpm exec vite build",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
